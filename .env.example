# AI Brain Website — Environment Variables
# Vercel Dashboard में जाकर इन्हें set करें:
# Settings → Environment Variables

# Gemini API Key (Google AI Studio से लें)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (platform.openai.com से लें)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (console.anthropic.com से लें)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
